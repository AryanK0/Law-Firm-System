{
  "name": "law-firm-system",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,green \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "python -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000 --reload",
    "frontend:dev": "npm run dev --workspace law-firm-frontend",
    "build": "npm run build --workspace law-firm-frontend",
    "preview": "npm run preview --workspace law-firm-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
