# =============================================================================
# Law firm app: FastAPI API + Vite frontend. Vercel hosts static UI only; the
# real API is FastAPI (local: npm run dev, production: Docker / Railway / etc.).
# =============================================================================
#
#   Example: https://your-service.up.railway.app/api
# Root Directory in Vercel = repo root. The Node `api/` folder is not deployed (.vercelignore).
#
# --- MySQL (FastAPI reads these; use .env.local at repo root for local dev) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lawfirm
# Hosted MySQL: set DB_SSL=true (and DB_SSL_INSECURE=true only for dev self-signed).
# DB_SSL=true
# DB_SSL_INSECURE=true
#
# --- FastAPI ---
# Writable uploads directory (default: ./uploads under repo root)
# UPLOAD_DIR=
#
# CORS: comma-separated origins, or leave unset for localhost Vite ports + *.vercel.app regex
# CORS_ORIGINS=https://your-app.vercel.app
#
#
# Local: Vite proxies /api and /uploads to FastAPI (default http://127.0.0.1:8000)
# VITE_LOCAL_API_PROXY=http://127.0.0.1:8000
