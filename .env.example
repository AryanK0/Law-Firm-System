# Vercel: Root Directory must be the repository root (not "frontend") so the api/ folder deploys.
#
# MySQL (required on Vercel: set in Project → Settings → Environment Variables)
# Local: copy to .env.local in the repo root; `vercel dev` loads .env.local automatically.
# Default host is 127.0.0.1 (avoids some Windows localhost → IPv6 issues).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lawfirm
# Hosted MySQL (PlanetScale, RDS, Azure, etc.) usually needs TLS:
# DB_SSL=true
# Dev only if the server uses a self-signed cert:
# DB_SSL_INSECURE=true
# DB_CONNECT_TIMEOUT_MS=15000
# DB_POOL_SIZE=5

# Vercel Blob — required for document uploads in production (Vercel serverless)
# Create a store in the Vercel dashboard and add the read-write token.
BLOB_READ_WRITE_TOKEN=

# Optional: only if the API is on another origin (default in app is /api)
# VITE_API_BASE_URL=https://your-api.example.com/api

# Local dev: Vite proxies /api to this URL (default matches `vercel dev` / `npm run dev:vercel` on port 3000)
# VITE_LOCAL_API_PROXY=http://localhost:3000
